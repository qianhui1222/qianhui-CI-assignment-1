#part 1 differential expression analysis

if (!requireNamespace("BiocManager", quietly = TRUE))
  install.packages("BiocManager")

BiocManager::install("DESeq2")
library(DESeq2)

rna.data <- read.table("TCGA.LIHC.sampleMap_HiSeqV2",sep="\t",head=TRUE,row.names=1)
rna.data <- as.data.frame(rna.data)
rna.data <- 2^rna.data-1
rna.data <- round(rna.data,digits=0)

group_list=factor(ifelse(as.numeric(substr(colnames(rna.data),14,15)) < 10,'tumor','normal'))
table(group_list)

patient <- colnames(rna.data)
metadata <- data.frame(sample_id = patient)
metadata$type <- group_list

dds <-DESeqDataSetFromMatrix(countData=rna.data, 
                             colData=metadata, 
                             design=~type)
dds <- dds[rowSums(counts(dds))>1,]
dds <- DESeq(dds)
contrast <- c("type", "tumor", "normal")
res <- results(dds, contrast=contrast)
res_order <- res[order(res$padj),]
deg <- res_order[!is.na(res_order$padj) &
                    res_order$padj<0.05 &
                    abs(res_order$log2FoldChange)>=0.6,]
deg <- as.data.frame(deg)
#20530 genes->7859 genes

rna.data <- read.table("TCGA.LIHC.sampleMap_HiSeqV2",sep="\t",head=TRUE,row.names=1)
rna.data <- as.matrix(rna.data)
deg.rna.data<-rna.data[rownames(deg),]
surv.data <- read.table("survival_LIHC_survival.txt", sep="\t", header=T,row.names=1)
rownames(surv.data)<-gsub(rownames(surv.data), pattern="-", replace=".")

med <- apply(deg.rna.data,1,median) 
med <- as.data.frame(med)
low <- which(apply(deg.rna.data,1,median) < 0.00001) 
deg.rna.data <- deg.rna.data[-low,]
#7859 genes ->7133 genes

#part 2 survival analysis

library(survival)
os.time <- surv.data[colnames(deg.rna.data),"OS.time"]
os.event <- as.numeric(surv.data[colnames(deg.rna.data),"OS"])
lihc.os <- Surv(os.time,os.event)

results.univariate<-array(NA, c(nrow(deg.rna.data),4))
colnames(results.univariate)<-c("HR","LCI","UCI","PVAL")
rownames(results.univariate)<-rownames(deg.rna.data)
results.univariate<-as.data.frame(results.univariate)
for(i in 1:nrow(deg.rna.data))
{
  
  coxphmodel <- coxph(lihc.os ~ as.numeric(deg.rna.data[i,]))
  results.univariate$HR[i] <- summary(coxphmodel)$coef[1,2]
  results.univariate$LCI[i] <- summary(coxphmodel)$conf.int[1,3]
  results.univariate$UCI[i] <- summary(coxphmodel)$conf.int[1,4]
  results.univariate$PVAL[i] <- summary(coxphmodel)$coef[1,5]
}
results.univariate<-as.data.frame(results.univariate)
results.univariate$FDR<-p.adjust(results.univariate$PVAL,method="fdr")
results.univariate<-results.univariate[order(results.univariate$FDR, decreasing=F),]
results.univariate[1:10,]

clin.data <- read.table("TCGA.LIHC.sampleMap_LIHC_clinicalMatrix", sep="\t", header=T, row.names=1)
rownames(clin.data)<-gsub(rownames(clin.data), pattern="-", replace=".")
clin.data<-clin.data[colnames(deg.rna.data),]

x1<-grep("Hepatitis",clin.data$viral_hepatitis_serology)
hepatitis<-rep(0,nrow(clin.data))
hepatitis[x1]<-1
summary(coxph(lihc.os ~ hepatitis))$coef

x1<-grep("No",clin.data$hist_hepato_carc_fact)
x2<-grep("Other",clin.data$hist_hepato_carc_fact)
risk<-rep(1,nrow(clin.data))
risk[c(x1,x2)]<-0
summary(coxph(lihc.os ~ risk))$coef

x3<-grep("III",clin.data$pathologic_stage)
x4<-grep("IV",clin.data$pathologic_stage)
stage.high<-rep(0,nrow(clin.data))
stage.high[c(x3,x4)]<-1
summary(coxph(lihc.os ~ stage.high))$coef

results.multivariate<-array(NA, c(nrow(deg.rna.data),4))
colnames(results.multivariate)<-c("HR","LCI","UCI","PVAL")
rownames(results.multivariate)<-rownames(deg.rna.data)
results.multivariate<-as.data.frame(results.multivariate)

for(i in 1:nrow(deg.rna.data))
{
  coxphmodel <- coxph(lihc.os ~ deg.rna.data[i,]+hepatitis+stage.high+risk)
  results.multivariate$HR[i] <- summary(coxphmodel)$coef[1,2]
  results.multivariate$LCI[i] <- summary(coxphmodel)$conf.int[1,3]
  results.multivariate$UCI[i] <- summary(coxphmodel)$conf.int[1,4]
  results.multivariate$PVAL[i] <- summary(coxphmodel)$coef[1,5]
}

results.multivariate<-as.data.frame(results.multivariate)
results.multivariate$FDR<-p.adjust(results.multivariate$PVAL,method="fdr")
results.multivariate<-results.multivariate[order(results.multivariate$FDR, decreasing=F),]
results.multivariate[1:10,]
