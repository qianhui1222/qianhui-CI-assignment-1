#part 3 DNA methylation analysis

meth.data<-read.table("TCGA.LIHC.sampleMap_HumanMethylation450", sep="\t", header=T, row.names=1)
meth.annot<-readRDS("annot450k.rds")
meth.TRNP1<-rownames(meth.annot[which(meth.annot$UCSC_RefGene_Name=="TRNP1"),])

rna.data2<-deg.rna.data[,which(is.element(colnames(deg.rna.data),colnames(meth.data)))]
meth.data2<-meth.data[,which(is.element(colnames(meth.data),colnames(rna.data2)))]
surv.data2<-surv.data[which(is.element(rownames(surv.data),colnames(rna.data2))),]

rna.data2<-as.matrix(rna.data2[,order(colnames(rna.data2))])
meth.data2<-as.matrix(meth.data2[,order(colnames(meth.data2))])
surv.data2<-as.data.frame(surv.data2[rownames(surv.data2),])

cg.TRNP1<-rownames(meth.annot[which(meth.annot$UCSC_RefGene_Name=="TRNP1"),])

meth.TRNP1<-meth.data2[cg.TRNP1,]
na.count<-apply(meth.TRNP1,1,function(x) sum(as.numeric(is.na(x))))
exclude<-as.numeric(na.count>0.5*ncol(meth.TRNP1))
meth.TRNP1<-meth.TRNP1[which(exclude==0),]

results<-array(NA,c(nrow(meth.TRNP1),4))
rownames(results)<-rownames(meth.TRNP1)
colnames(results)<-c("Cor.TRNP1","Cor.test.TRNP1","Mean.high.TRNP1","Mean.low.TRNP1")
TRNP1.high2 <- as.numeric(as.numeric(rna.data2["TRNP1",])>median(as.numeric(rna.data2["TRNP1",])))
for (i in 1:nrow(meth.TRNP1))
{
  results[i,1]<-cor.test(as.numeric(rna.data2["TRNP1",]),as.numeric(meth.TRNP1[i,]), method = "spearman")$est
  results[i,2]<-cor.test(as.numeric(rna.data2["TRNP1",]),as.numeric(meth.TRNP1[i,]), method = "spearman")$p.value
}

results[,3]<-apply(meth.TRNP1[,which(TRNP1.high2==1)],1,mean,na.rm=T)
results[,4]<-apply(meth.TRNP1[,which(TRNP1.high2==0)],1,mean,na.rm=T)
results<-as.data.frame(results)
results$FDR<-p.adjust(results$Cor.test.TRNP1,method="fdr")
results<-results[order(results$FDR, decreasing=F),]
